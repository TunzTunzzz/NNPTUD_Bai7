{
  "info": {
    "name": "Inventory API Collection",
    "description": "Postman Collection cho module Inventory",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Tạo Product & Inventory (POST /api/v1/products)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Sản phẩm test kho cuối cùng\",\n  \"price\": 100000,\n  \"description\": \"Mô tả SP\",\n  \"categoryId\": \"666be5f309d4351b8c2579b7\",\n  \"stock\": 10\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/products",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "products"]
        }
      }
    },
    {
      "name": "Lấy toàn bộ Inventory (GET /api/v1/inventories)",
